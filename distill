#!/bin/sh
# SpecForge Distill - POSIX development runner
# Usage: ./distill path/to/spec.pdf [args]

set -eu

DIR=$(
    CDPATH= cd -- "$(dirname -- "$0")" >/dev/null 2>&1 && pwd
)

if [ -x "$DIR/.venv/bin/python" ]; then
    PYTHON_BIN="$DIR/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN=$(command -v python3)
elif command -v python >/dev/null 2>&1; then
    PYTHON_BIN=$(command -v python)
else
    echo "error: python was not found. Use a release binary from GitHub Releases instead." >&2
    exit 127
fi

export DISTILL_SELECTED_PYTHON="$PYTHON_BIN"
exec "$PYTHON_BIN" "$DIR/scripts/run_local_dev.py" "$@"
